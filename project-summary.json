  "js_modules": {
    "js/localdb.js": {
      "purpose": "localStorage-based Supabase API replacement",
      "key_classes": ["LocalSupabase", "QueryBuilder"],
      "key_functions": [
        "getStorageStats()",
        "exportLocalBackup()",
        "importLocalBackup(file)",
        "clearAllData()",
        "refreshStorageStatus()"
      ],
      "tables": ["b2b_invoices", "b2c_invoices", "b2b_hsn", "b2c_hsn", "customers", "cdn_notes"],
      "notes": "QueryBuilder supports: select, insert, update, delete, eq, gte, lte, order, single. INSERT preserves payload.id if provided (profiles). UPDATE matches by all eq filters."
    },
    "js/config.js": {
      "purpose": "Supabase vs LocalSupabase switch",
      "key_vars": ["IS_LOCAL_MODE", "_supabase"],
      "notes": "IS_LOCAL_MODE = true when SUPABASE_URL is placeholder. Must load localdb.js BEFORE config.js."
    },
    "js/auth.js": {
      "purpose": "Authentication helpers",
      "key_functions": ["requireAuth()", "getCurrentUser()", "logout()"],
      "notes": "In local mode returns LOCAL_USER = { id: 'local-demo-user-001' } immediately"
    },
    "js/profile.js": {
      "purpose": "Business profile setup, settings modal, PDF/print letterhead",
      "key_functions": [
        "loadUserProfile(userId)",
        "saveUserProfile(userId, fields)",
        "checkAndShowProfileSetup(userId)",
        "openProfileModal(isRequired)",
        "openSettingsModal()",
        "getBusinessPDFHeader(doc, title, period)",
        "getBusinessPrintHTML()",
        "getCachedProfile()"
      ],
      "localStorage_key": "gst_profiles",
      "notes": "Auto-migrates profile saved with wrong UUID. Profile popup has X button and Skip for Now button (always dismissable)."
    },
    "js/export.js": {
      "purpose": "Excel, PDF, Print, JSON export",
      "key_functions": [
        "exportToExcel(data, sheetName, fileName)",
        "exportMultiSheetExcel(sheets, fileName)",
        "exportToPDF(title, columns, rows, fileName)",
        "exportB2BExcel(invoices)",
        "exportB2CExcel(invoices)",
        "exportHSNExcel(b2bHsn, b2cHsn)",
        "exportB2BPDF(invoices)",
        "exportB2CPDF(invoices)",
        "exportGSTR1JSON(b2b, b2c, b2bHsn)",
        "printReport(elementId, reportTitle)"
      ],
      "notes": "exportGSTR1JSON produces standard Indian GSTR-1 format with b2b (grouped by GSTIN), b2cs (grouped by state+rate), hsn sections."
    },
    "js/gstr1.js": {
      "purpose": "B2B Invoice CRUD + Auto Invoice No + WhatsApp Share",
      "key_functions": [
        "initB2B()",
        "saveB2B()",
        "resetB2B()",
        "loadB2B(userId)",
        "generateInvoiceNo(userId, force)",
        "isAutoInvoiceOn()",
        "onAutoToggleChange()",
        "updateAutoToggleUI()",
        "loadCustomersList(userId)",
        "onCustomerSelect()",
        "saveCustomerFromForm()",
        "shareWhatsApp(id)",
        "editB2B(id)",
        "deleteB2B(id)"
      ],
      "localStorage_key_toggle": "gst_auto_invoice",
      "notes": "generateInvoiceNo: scans existing invoice numbers, finds max, increments. force=true bypasses toggle check. sessionStorage 'prefill_customer' used for Customer Master → B2B redirect."
    },
    "js/customers.js": {
      "purpose": "Customer Master CRUD",
      "key_functions": ["initCustomers()", "saveCustomer()", "loadCustomers(userId)", "editCustomer(id)", "deleteCustomer(id)", "useInB2B(id)"]
    },
    "js/cdnotes.js": {
      "purpose": "Credit/Debit Notes CRUD",
      "key_functions": ["initCDNotes()", "saveCDNote()", "loadCDNotes(userId)", "editCDNote(id)", "deleteCDNote(id)"]
    },
    "js/utils.js": {
      "purpose": "Shared utilities",
      "key_functions": [
        "formatNum(n)",
        "formatDate(d)",
        "calcGST(taxableAmount, gstPct, supplyType)",
        "showToast(message, type)",
        "showConfirm(message)",
        "initNavUser(user)",
        "setupLogoutBtn()",
        "setupMobileMenu()",
        "INDIAN_STATES (array)"
      ],
      "notes": "calcGST returns { igst, cgst, sgst, gstAmount, totalAmount }. IGST for interstate, CGST+SGST for intrastate."
    },
    "js/dashboard.js": {
      "purpose": "Chart rendering only",
      "key_functions": ["renderCharts(b2b, b2c)"],
      "notes": "Data loading and year/month filter logic is in dashboard.html inline script."
    },
    "js/reports.js": {
      "purpose": "Reports page data loading and export",
      "key_functions": ["initReports()", "loadReports(month)", "exportFullGSTR1()", "exportSummaryPDF()"]
    },
    "js/hsn.js": {
      "purpose": "HSN Summary CRUD + tab switching",
      "key_functions": ["initHSN()", "saveHSN(prefix)", "loadB2BHSN(userId)", "loadB2CHSN(userId)", "switchHSNTab(tab)", "hsnTabClick(tab)"]
    }
  },

