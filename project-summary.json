{
  "_meta": {
    "project": "GST Invoice & GSTR-1 Management System",
    "version": "2.0",
    "generated": "2026-06-06",
    "author": "ledvtech@gmail.com",
    "description": "Offline-first GST Invoice & GSTR-1 web app for India. Works fully in browser with localStorage. No login required. Supabase-ready when credentials are added.",
    "base_path": "c:/Users/admin/OneDrive/Desktop/gst.file/"
  },

  "tech_stack": {
    "frontend": "Vanilla HTML + CSS + JavaScript (no framework)",
    "database": "localStorage (offline) / Supabase PostgreSQL (cloud-ready)",
    "charts": "Chart.js (CDN)",
    "excel_export": "SheetJS / xlsx (CDN)",
    "pdf_export": "jsPDF + jsPDF-AutoTable (CDN)",
    "icons": "Font Awesome 6.5 (CDN)",
    "auth": "Supabase Auth (bypassed in local mode — LOCAL_USER used)",
    "routing": "URL hash (#b2b / #b2c) for HSN tabs"
  },

  "pages": {
    "dashboard.html": {
      "title": "Dashboard",
      "js": ["js/dashboard.js"],
      "features": [
        "Stat cards: B2B count, B2C count, Total GST, Grand Total",
        "Year dropdown (5 years) + Month dropdown (All / Jan–Dec)",
        "Bar chart: Monthly Revenue",
        "Doughnut chart: GST Distribution (IGST/CGST/SGST)",
        "12-month summary table for selected year",
        "Storage status bar: B2B/B2C/HSN record counts",
        "Backup and Restore buttons",
        "Business profile setup on first visit",
        "Settings gear icon"
      ]
    },
    "gstr1.html": {
      "title": "B2B Invoices",
      "js": ["js/gstr1.js"],
      "features": [
        "B2B Invoice entry: GSTIN, Customer Name, Invoice No, Date, Taxable Amount, GST%, Supply Type",
        "Auto GST calculation: IGST (interstate) / CGST+SGST (intrastate)",
        "Invoice Number Auto-generate: INV-2026-001 (toggle ON/OFF)",
        "Customer autocomplete datalist from Customer Master",
        "Save customer to master (+ button)",
        "Duplicate invoice number check",
        "GSTIN format validation (warning only)",
        "WhatsApp share button per invoice",
        "Excel + PDF export",
        "Search by GSTIN / Customer / Invoice No",
        "Pagination (10 per page)"
      ]
    },
    "b2c.html": {
