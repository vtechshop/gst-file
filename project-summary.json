  "supabase_migration": {
    "steps": [
      "1. Create Supabase project at supabase.com",
      "2. Run supabase-schema.sql in SQL editor",
      "3. In js/config.js replace YOUR_SUPABASE_PROJECT_URL and YOUR_SUPABASE_ANON_KEY",
      "4. IS_LOCAL_MODE auto-switches to false — real Supabase used",
      "5. All pages work identically — no other changes needed"
    ]
  },

