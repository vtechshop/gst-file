        "Excel + PDF export",
        "Search by state",
        "Pagination"
      ]
    },
    "hsn.html": {
      "title": "HSN Summary",
      "js": ["js/hsn.js"],
      "features": [
        "Two tabs: B2B HSN and B2C HSN",
        "URL hash routing: hsn.html#b2b / hsn.html#b2c",
        "Sidebar links independently open correct tab",
        "HSN Code, Product Name, Type (Goods/Service), Quantity, Taxable Value, GST%, Supply Type",
        "Auto GST calculation",
        "Totals row in table footer",
        "Excel export per tab"
      ]
    },
    "reports.html": {
      "title": "Reports & Export",
      "js": ["js/reports.js"],
      "features": [
        "Month filter dropdown",
