        "GSTR-1 Summary table",
        "B2B Detail table",
        "B2C Detail table",
        "Month-wise GST report",
        "HSN Summary report",
        "Export: Full GSTR-1 Excel (multi-sheet)",
        "Export: Summary PDF (with letterhead)",
        "Export: B2B Excel, B2C Excel, HSN Excel",
        "Export: GSTR-1 JSON (Government Portal format)",
