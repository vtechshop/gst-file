# Copy this file to .env in this same folder and fill in real values.
# .env is git-ignored (see ../.gitignore) — it never gets committed and
# never ships to the browser.

# Port this proxy server listens on.
PORT=4000

# Origin(s) allowed to call this proxy — set to wherever the Billing
# System frontend is actually served from (comma-separated for more
# than one, e.g. local dev + your GitHub Pages URL).
ALLOWED_ORIGIN=http://localhost:5500

# NOTE: there is no WEBSITE_PRODUCT_API_URL/KEY here — every account is
# its own company with its own product API, configured per-company in
# Business Profile > Settings (stored in profiles.product_api_url/
# product_api_key), never as a single global setting. See
# server/routes/product-sync.js.

# PostgreSQL connection string. Point this at your real database when
# you have one — the code doesn't care whether it's a local install, a
# Docker container, or a hosted instance (Render/Railway/RDS/etc.), as
# long as it's a Postgres connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gst_invoicing

# JWT signing secret — generate a long random string for real use
# (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`).
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
